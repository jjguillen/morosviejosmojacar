---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CarritoTienda from '../components/tienda/CarritoTienda.astro';

const productos = await getCollection('productos', ({ data }) => data.activo);

const porCategoria = {
  ropa: productos.filter((p) => p.data.categoria === 'ropa'),
  complementos: productos.filter((p) => p.data.categoria === 'complementos'),
  indumentaria: productos.filter((p) => p.data.categoria === 'indumentaria'),
};
---

<BaseLayout
  title="Tienda — Moros Viejos"
  description="Adquiere los productos oficiales de la Kabila Alí-Cuquei. Camisetas, polos, sudaderas, gorros, bolsos, pins y chilabas."
>
  <div class="page">
    <PageHeader
      title="Tienda oficial"
      subtitle="Selecciona los productos, elige talla y cantidad. Una vez enviado el pedido, nos pondremos en contacto contigo para cerrar los detalles."
    />

    <div class="container">
      <CarritoTienda productos={productos} />
    </div>
  </div>
</BaseLayout>

<style>
  @media (max-width: 768px) {
    /* Espacio para que la barra flotante no tape el último producto */
    .page {
      padding-bottom: 5rem;
    }
  }
</style>
