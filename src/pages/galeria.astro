---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import PhotoFilter from '../components/PhotoFilter.astro';

const galerias = await getCollection('galeria');
galerias.sort((a, b) => b.data.year - a.data.year);

const years = galerias.map((g) => g.data.year);
const selectedYear = years[0] ?? 0;
---

<BaseLayout title="Galería">
  <div class="page">
    <header class="page-header">
      <div class="container">
        <h1 class="page-title">Galer&iacute;a</h1>
        <p class="page-subtitle">
          Im&aacute;genes de nuestros desfiles, actividades y momentos inolvidables
        </p>
      </div>
    </header>

    <div class="container">
      {galerias.length > 0 ? (
        <>
          {years.length > 1 && (
            <PhotoFilter years={years} selectedYear={selectedYear} client:load />
          )}
          {galerias.map((galeria) => (
            <section
              data-gallery-year={galeria.data.year}
              style:list={{
                display: selectedYear !== galeria.data.year ? 'none' : undefined,
              }}
            >
              <h2 class="section__year">{galeria.data.year}</h2>
              <GalleryGrid photos={galeria.data.photos} />
            </section>
          ))}
        </>
      ) : (
        <p class="galeria__empty">Pronto a&ntilde;adiremos fotos de nuestros desfiles.</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    text-align: center;
    padding: var(--space-4xl) 0 var(--space-3xl);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    color: var(--color-text-1);
    margin-bottom: var(--space-md);
  }

  .page-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-2);
    max-width: 36rem;
    margin: 0 auto;
  }

  .section__year {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--color-accent-2);
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .galeria__empty {
    text-align: center;
    color: var(--color-text-3);
    font-size: var(--text-lg);
    padding: var(--space-4xl) 0;
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: var(--text-3xl);
    }
  }
</style>
