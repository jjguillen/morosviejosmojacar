---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import PhotoFilter from '../components/PhotoFilter.astro';

const galerias = await getCollection('galeria');
galerias.sort((a, b) => b.data.year - a.data.year);

const years = galerias.map((g) => g.data.year);
const selectedYear = years[0] ?? 0;
---

<BaseLayout title="Galería">
  <div class="page">
    <PageHeader
      title="Galería"
      subtitle="Imágenes de nuestros desfiles, actividades y momentos inolvidables"
    />

    <div class="container">
      {galerias.length > 0 ? (
        <>
          {years.length > 1 && (
            <PhotoFilter years={years} selectedYear={selectedYear} />
          )}
          {galerias.map((galeria) => (
            <section
              data-gallery-year={galeria.data.year}
              style:list={{
                display: selectedYear !== galeria.data.year ? 'none' : undefined,
              }}
            >
              <h2 class="section__year">{galeria.data.year}</h2>
              <GalleryGrid photos={galeria.data.photos} />
            </section>
          ))}
        </>
      ) : (
        <p class="galeria__empty">Pronto a&ntilde;adiremos fotos de nuestros desfiles.</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .section__year {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--color-accent-2);
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .galeria__empty {
    text-align: center;
    color: var(--color-text-3);
    font-size: var(--text-lg);
    padding: var(--space-4xl) 0;
  }

</style>
