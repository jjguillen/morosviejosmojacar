---
export interface Props {
  years: number[];
  selectedYear: number;
}

const { years, selectedYear } = Astro.props;
---

<div class="filter">
  <span class="filter__label">Filtrar por año:</span>
  <div class="filter__buttons" id="year-filter">
    {years.map((year) => (
      <button
        type="button"
        class:list={[
          'filter__btn',
          { 'filter__btn--active': year === selectedYear },
        ]}
        data-year={String(year)}
        data-active={year === selectedYear ? 'true' : 'false'}
      >
        {year}
      </button>
    ))}
  </div>
</div>

<style>
  .filter {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }

  .filter__label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .filter__buttons {
    display: flex;
    gap: var(--space-sm);
  }

  .filter__btn {
    padding: var(--space-xs) var(--space-md);
    font-size: var(--text-sm);
    font-weight: 600;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface-2);
    color: var(--color-text-2);
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .filter__btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .filter__btn--active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }
</style>

<script>
  document.getElementById('year-filter')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.filter__btn');
    if (!btn) return;

    const year = btn.dataset.year;
    if (!year) return;

    // Update active state
    document.querySelectorAll('.filter__btn').forEach((b) => {
      b.classList.toggle('filter__btn--active', b === btn);
    });

    // Show/hide gallery sections
    document.querySelectorAll<HTMLElement>('[data-gallery-year]').forEach((section) => {
      section.style.display = section.dataset.galleryYear === year ? '' : 'none';
    });
  });
</script>
