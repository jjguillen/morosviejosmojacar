---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  producto: CollectionEntry<'productos'>;
}

const { producto } = Astro.props;
const { id, nombre, descripcion, precio, tallas, imagen } = producto.data;
---

<article class="producto-card" data-producto-id={id}>
  <div class="producto-card__img">
    {imagen ? (
      <img
        src={imagen}
        alt={nombre}
        class="producto-card__foto"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <svg viewBox="0 0 80 80" fill="none" aria-hidden="true">
        <rect width="80" height="80" rx="16" fill="var(--color-accent)" opacity="0.08"/>
        <path d="M24 48h32l-8-18H32l-8 18z" stroke="var(--color-accent)" stroke-width="2" fill="none"/>
        <circle cx="30" cy="52" r="3.5" fill="var(--color-accent)" opacity="0.5"/>
        <circle cx="50" cy="52" r="3.5" fill="var(--color-accent)" opacity="0.5"/>
      </svg>
    )}
  </div>

  <div class="producto-card__body">
    <h3 class="producto-card__name">{nombre}</h3>
    {descripcion && <p class="producto-card__desc">{descripcion}</p>}
    <span class="producto-card__price">{precio} €</span>

    <div class="producto-card__controls">
      {tallas ? (
        <select class="producto-card__talla" name={`talla-${id}`} aria-label="Talla">
          <option value="">Talla</option>
          {tallas.map((t) => <option value={t}>{t}</option>)}
        </select>
      ) : (
        <span class="producto-card__no-talla">Sin talla</span>
      )}
      <div class="producto-card__qty-row">
        <input
          type="number"
          class="producto-card__qty"
          name={`qty-${id}`}
          min="1"
          max="20"
          value="1"
          aria-label="Cantidad"
        />
        <button type="button" class="btn btn--add producto-card__add" data-add={id}>
          A&ntilde;adir
        </button>
      </div>
    </div>
  </div>
</article>

<style>
  .producto-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    background-color: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: box-shadow 0.3s ease, background-color 0.3s ease;
  }

  .producto-card:hover {
    box-shadow: var(--shadow-md);
  }

  .producto-card__img {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-surface-1);
    padding: var(--space-lg);
    min-height: 160px;
  }

  .producto-card__img svg {
    width: 100%;
    height: 100%;
    max-width: 120px;
    max-height: 120px;
  }

  .producto-card__foto {
    width: 100%;
    height: 100%;
    object-fit: contain;
    max-width: 200px;
    max-height: 200px;
  }

  .producto-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-lg) var(--space-lg) var(--space-lg) 0;
    min-width: 0;
  }

  .producto-card__name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--color-text-1);
  }

  .producto-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-2);
    line-height: 1.5;
  }

  .producto-card__price {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-accent);
    margin: var(--space-xs) 0;
  }

  .producto-card__controls {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: auto;
  }

  .producto-card__talla {
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--text-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background-color: var(--color-surface-1);
    color: var(--color-text-1);
    cursor: pointer;
  }

  .producto-card__talla:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .producto-card__no-talla {
    font-size: var(--text-xs);
    color: var(--color-text-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .producto-card__qty-row {
    display: flex;
    gap: var(--space-sm);
    align-items: center;
  }

  .producto-card__qty {
    width: 3.5rem;
    padding: var(--space-xs);
    font-size: var(--text-sm);
    text-align: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background-color: var(--color-surface-1);
    color: var(--color-text-1);
  }

  .producto-card__qty:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .btn--add {
    padding: var(--space-xs) var(--space-md);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-sm);
    background-color: var(--color-accent);
    color: #fff;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.2s ease;
  }

  .btn--add:hover {
    background-color: var(--color-accent-hover);
  }

  @media (max-width: 768px) {
    .producto-card {
      grid-template-columns: 1fr 1fr;
    }

    .producto-card__img svg {
      max-width: 80px;
      max-height: 80px;
    }
  }
</style>
