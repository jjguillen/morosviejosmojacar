---
import type { CollectionEntry } from 'astro:content';
import ProductoCard from './ProductoCard.astro';

export interface Props {
  productos: CollectionEntry<'productos'>[];
}

const { productos } = Astro.props;

const categorias = ['ropa', 'complementos', 'indumentaria'] as const;
const catLabels: Record<string, string> = {
  ropa: 'Ropa',
  complementos: 'Complementos',
  indumentaria: 'Indumentaria',
};

const porCategoria = categorias
  .map((cat) => ({
    cat,
    label: catLabels[cat],
    items: productos.filter((p) => p.data.categoria === cat),
  }))
  .filter((g) => g.items.length > 0);
---

<div class="tienda" id="tienda-root">
  <div class="tienda-layout">
    <!-- Catálogo -->
    <section class="tienda-catalogo" id="tienda-catalogo">
      {porCategoria.map(({ cat, label, items }) => (
        <div class="catalogo__grupo">
          <h2 class="catalogo__cat-title">{label}</h2>
          <div class="catalogo__grid">
            {items.map((prod) => (
              <ProductoCard producto={prod} />
            ))}
          </div>
        </div>
      ))}
    </section>

    <!-- Panel del pedido (desktop) -->
    <aside class="pedido-panel" id="pedido-panel">
      <h3 class="pedido-panel__titulo">Tu pedido</h3>

      <!-- Estado vacío -->
      <div class="carrito-vacio" id="carrito-vacio">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        <p>Tu pedido está vacío</p>
        <span>Añade productos del catálogo</span>
      </div>

      <!-- Tabla del pedido -->
      <div class="pedido-tabla-wrapper" id="pedido-tabla-wrapper" hidden>
        <table class="pedido-tabla" aria-label="Resumen del pedido">
          <thead>
            <tr>
              <th scope="col" class="col-nombre">Producto</th>
              <th scope="col" class="col-cantidad">Cant.</th>
              <th scope="col" class="col-precio">Precio</th>
              <th scope="col" class="col-accion"><span class="sr-only">Eliminar</span></th>
            </tr>
          </thead>
          <tbody id="pedido-lineas" aria-live="polite"></tbody>
          <tfoot>
            <tr class="pedido-total-row">
              <td colspan="2" class="pedido-total-label">Total</td>
              <td class="pedido-total-valor" id="pedido-total">0,00 €</td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>

      <!-- Acciones -->
      <div class="pedido-acciones" id="pedido-acciones" hidden>
        <button type="button" class="btn btn--outline btn--sm" id="pedido-vaciar">Vaciar pedido</button>
        <button type="button" class="btn btn--primary btn--full" id="pedido-finalizar" disabled>Finalizar pedido</button>
      </div>

      <!-- Formulario -->
      <div id="formulario-container"></div>
    </aside>
  </div>

  <!-- ── Barra flotante móvil ── -->
  <div class="barra-movil" id="barra-pedido-movil" aria-hidden="true">
    <button type="button" class="barra-movil__btn" id="barra-abrir-drawer" aria-haspopup="dialog">
      <svg class="barra-movil__icono" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
      </svg>
      <span class="barra-movil__texto">Ver pedido</span>
      <span class="barra-movil__badge" id="barra-badge">0</span>
    </button>
    <span class="barra-movil__total" id="barra-total">0,00 €</span>
  </div>

  <!-- ── Overlay ── -->
  <div class="drawer-overlay" id="drawer-overlay" aria-hidden="true"></div>

  <!-- ── Drawer móvil ── -->
  <div class="drawer" id="drawer-pedido" role="dialog" aria-modal="true" aria-label="Tu pedido" aria-hidden="true">
    <div class="drawer__header">
      <h3 class="drawer__titulo">Tu pedido</h3>
      <button type="button" class="drawer__cerrar" id="drawer-cerrar" aria-label="Cerrar pedido">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="drawer__body">
      <!-- Estado vacío -->
      <div class="carrito-vacio" id="carrito-vacio-movil">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        <p>Tu pedido está vacío</p>
        <span>Añade productos del catálogo</span>
      </div>

      <!-- Tabla del pedido -->
      <div class="pedido-tabla-wrapper" id="pedido-tabla-wrapper-movil" hidden>
        <table class="pedido-tabla" aria-label="Resumen del pedido">
          <thead>
            <tr>
              <th scope="col" class="col-nombre">Producto</th>
              <th scope="col" class="col-cantidad">Cant.</th>
              <th scope="col" class="col-precio">Precio</th>
              <th scope="col" class="col-accion"><span class="sr-only">Eliminar</span></th>
            </tr>
          </thead>
          <tbody id="pedido-lineas-movil" aria-live="polite"></tbody>
          <tfoot>
            <tr class="pedido-total-row">
              <td colspan="2" class="pedido-total-label">Total</td>
              <td class="pedido-total-valor" id="pedido-total-movil">0,00 €</td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>

      <!-- Acciones -->
      <div class="pedido-acciones" id="pedido-acciones-movil" hidden>
        <button type="button" class="btn btn--outline btn--sm" id="pedido-vaciar-movil">Vaciar pedido</button>
        <button type="button" class="btn btn--primary btn--full" id="pedido-finalizar-movil" disabled>Finalizar pedido</button>
      </div>

      <!-- Formulario -->
      <div id="formulario-container-movil"></div>
    </div>
  </div>
</div>

<style>
  .tienda-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: start;
    padding-block: var(--space-2xl);
  }

  /* ── Catálogo ── */
  .catalogo__grupo { margin-bottom: var(--space-2xl); }

  .catalogo__cat-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--color-accent-2);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .catalogo__grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  /* ── Panel (desktop) ── */
  .pedido-panel {
    position: sticky;
    top: calc(var(--header-height) + var(--space-xl));
    background-color: var(--color-surface-1);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-md);
  }

  .pedido-panel__titulo {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text-1);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Estado vacío ── */
  .carrito-vacio {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-sm);
    padding: var(--space-2xl) var(--space-lg);
    color: var(--color-text-3);
  }

  .carrito-vacio p {
    font-weight: 500;
    color: var(--color-text-2);
  }

  .carrito-vacio span {
    font-size: var(--text-xs);
  }

  .carrito-vacio[hidden] { display: none; }

  /* ── Tabla del pedido ── */
  .pedido-tabla-wrapper {
    width: 100%;
    overflow: hidden;
  }

  .pedido-tabla-wrapper[hidden] { display: none; }

  .pedido-tabla {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    table-layout: fixed;
  }

  .pedido-tabla .col-nombre { width: auto; }
  .pedido-tabla .col-cantidad { width: 86px; }
  .pedido-tabla .col-precio { width: 68px; }
  .pedido-tabla .col-accion { width: 40px; }

  .pedido-tabla thead th {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0 0 var(--space-xs);
    border-bottom: 2px solid var(--color-border);
    text-align: left;
  }

  .pedido-tabla thead .col-precio,
  .pedido-tabla thead .col-cantidad { text-align: center; }

  .pedido-tabla tbody tr {
    border-bottom: 1px solid var(--color-border);
    transition: background-color 0.2s ease;
  }

  .pedido-tabla tbody tr:hover {
    background-color: var(--color-surface-2);
  }

  .pedido-tabla td {
    padding: var(--space-sm);
    vertical-align: middle;
  }

  .linea-nombre {
    display: block;
    font-weight: 600;
    color: var(--color-text-1);
    font-size: var(--text-sm);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .linea-talla {
    display: inline-block;
    margin-top: 2px;
    font-size: var(--text-xs);
    color: var(--color-text-3);
    background-color: var(--color-surface-2);
    border-radius: var(--radius-sm);
    padding: 1px var(--space-sm);
  }

  /* Controles inyectados por JS — :global para que apliquen los estilos scoped */
  :global(.cantidad-control) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  :global(.icon-btn) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    padding: 0;
    margin: 0;
    border: none;
    border-radius: 50%;
    background: transparent;
    color: var(--color-accent);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  :global(.icon-btn svg) {
    display: block;
    pointer-events: none;
  }

  :global(.icon-btn:hover) {
    background-color: color-mix(in srgb, var(--color-accent) 14%, transparent);
  }

  :global(.icon-btn:active) {
    background-color: color-mix(in srgb, var(--color-accent) 24%, transparent);
  }

  :global(.icon-btn:focus-visible) {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }

  :global(.icon-btn--eliminar) {
    color: var(--color-text-3);
  }

  :global(.icon-btn--eliminar:hover) {
    color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-accent) 14%, transparent);
  }

  :global(.cantidad-valor) {
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-text-1);
    min-width: 1.75ch;
    text-align: center;
    user-select: none;
  }

  .pedido-tabla .col-precio {
    text-align: right;
    font-weight: 600;
    color: var(--color-accent);
    white-space: nowrap;
  }

  .pedido-tabla .col-accion :global(.icon-btn) {
    margin: 0 auto;
  }

  /* ── Fila del total ── */
  .pedido-total-row td {
    padding: var(--space-sm);
    border-top: 2px solid var(--color-border);
  }

  .pedido-total-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pedido-total-valor {
    text-align: right;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text-1);
    white-space: nowrap;
  }

  /* ── Acciones ── */
  .pedido-acciones {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .pedido-acciones[hidden] { display: none; }

  .btn--primary:disabled { opacity: 0.5; cursor: not-allowed; }

  .btn--outline {
    background: none;
    border-color: var(--color-border);
    color: var(--color-text-2);
  }

  .btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  .btn--sm { padding: var(--space-xs) var(--space-md); font-size: var(--text-xs); }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border-width: 0;
  }

  @media (max-width: 768px) {
    .tienda-layout {
      grid-template-columns: 1fr;
    }

    /* Panel desktop oculto en móvil — lo sustituye el drawer */
    .pedido-panel {
      display: none;
    }

    .pedido-tabla .col-cantidad { width: 90px; }
    .pedido-tabla .col-precio { width: 64px; }
  }

  /* ── Barra flotante móvil ── */
  .barra-movil {
    display: none;
  }

  @media (max-width: 768px) {
    .barra-movil {
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 200;
      background-color: var(--color-accent);
      color: #fff;
      padding: var(--space-md) var(--space-lg);
      padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom, 0px));
      box-shadow: 0 -2px 16px rgba(0, 0, 0, 0.18);
      transform: translateY(100%);
      transition: transform 0.3s ease;
    }

    .barra-movil.barra-movil--visible {
      transform: translateY(0);
    }

    .barra-movil__btn {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      background: none;
      border: none;
      color: #fff;
      cursor: pointer;
      font-size: var(--text-base);
      font-weight: 600;
      padding: 0;
      -webkit-tap-highlight-color: transparent;
    }

    .barra-movil__icono {
      flex-shrink: 0;
    }

    .barra-movil__badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 1.4rem;
      height: 1.4rem;
      padding: 0 var(--space-xs);
      background-color: #fff;
      color: var(--color-accent);
      font-size: var(--text-xs);
      font-weight: 700;
      border-radius: 999px;
      line-height: 1;
    }

    .barra-movil__total {
      font-family: var(--font-display);
      font-size: var(--text-lg);
      font-weight: 700;
      color: #fff;
      white-space: nowrap;
    }
  }

  /* ── Overlay ── */
  .drawer-overlay {
    display: none;
  }

  @media (max-width: 768px) {
    .drawer-overlay {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 201;
      background-color: rgba(0, 0, 0, 0.5);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }

    .drawer-overlay.drawer-overlay--visible {
      opacity: 1;
      pointer-events: auto;
    }
  }

  /* ── Drawer ── */
  .drawer {
    display: none;
  }

  @media (max-width: 768px) {
    .drawer {
      display: flex;
      flex-direction: column;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 202;
      max-height: 85vh;
      background-color: var(--color-surface-1);
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
      box-shadow: 0 -4px 32px rgba(0, 0, 0, 0.18);
      transform: translateY(100%);
      transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
      padding-bottom: env(safe-area-inset-bottom, 0px);
    }

    .drawer.drawer--open {
      transform: translateY(0);
    }

    .drawer__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--space-md) var(--space-lg);
      border-bottom: 1px solid var(--color-border);
      flex-shrink: 0;
    }

    .drawer__titulo {
      font-family: var(--font-display);
      font-size: var(--text-lg);
      font-weight: 600;
      color: var(--color-text-1);
    }

    .drawer__cerrar {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.25rem;
      height: 2.25rem;
      border: none;
      border-radius: 50%;
      background: var(--color-surface-2);
      color: var(--color-text-2);
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      transition: background-color 0.2s ease, color 0.2s ease;
    }

    .drawer__cerrar:hover {
      background-color: var(--color-surface-3);
      color: var(--color-text-1);
    }

    .drawer__body {
      overflow-y: auto;
      padding: var(--space-lg);
      flex: 1;
      -webkit-overflow-scrolling: touch;
    }
  }
</style>

<script>
  interface LineaCarrito {
    id: string;
    nombre: string;
    talla: string;
    cantidad: number;
    precioUnit: number;
  }

  let carrito: LineaCarrito[] = [];
  let formularioVisible = false;

  // ── Helpers ──

  function calcularTotal(): number {
    return carrito.reduce((sum, l) => sum + l.precioUnit * l.cantidad, 0);
  }

  function calcularUnidades(): number {
    return carrito.reduce((sum, l) => sum + l.cantidad, 0);
  }

  function generarResumenTexto(): string {
    if (carrito.length === 0) return '';
    return carrito.map(l =>
      `${l.nombre}${l.talla ? ` (${l.talla})` : ''} x${l.cantidad} = ${(l.precioUnit * l.cantidad).toFixed(2)}€`
    ).join('\n') + '\n\nTOTAL: ' + calcularTotal().toFixed(2) + '€';
  }

  function formatEur(n: number): string {
    return n.toFixed(2).replace('.', ',') + ' €';
  }

  function filaHTML(l: LineaCarrito, i: number): string {
    const subtotal = l.cantidad * l.precioUnit;
    return `
      <tr data-id="${l.id}" data-talla="${l.talla}" data-idx="${i}">
        <td class="col-nombre">
          <span class="linea-nombre">${l.nombre}</span>
          ${l.talla ? `<span class="linea-talla">${l.talla}</span>` : ''}
        </td>
        <td class="col-cantidad">
          <div class="cantidad-control">
            <button type="button" class="icon-btn icon-btn--cantidad" data-accion="restar" data-idx="${i}" aria-label="Reducir cantidad de ${l.nombre}">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </button>
            <span class="cantidad-valor">${l.cantidad}</span>
            <button type="button" class="icon-btn icon-btn--cantidad" data-accion="sumar" data-idx="${i}" aria-label="Aumentar cantidad de ${l.nombre}">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </button>
          </div>
        </td>
        <td class="col-precio">${formatEur(subtotal)}</td>
        <td class="col-accion">
          <button type="button" class="icon-btn icon-btn--eliminar" data-eliminar="${i}" aria-label="Eliminar ${l.nombre}">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 3h6l1 2h4v2H4V5h4l1-2z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/><path d="M7 9v10a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/><path d="M10 12v6M14 12v6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>
          </button>
        </td>
      </tr>`;
  }

  // ── Drawer (móvil) ──

  function abrirDrawer() {
    const drawer = document.getElementById('drawer-pedido');
    const overlay = document.getElementById('drawer-overlay');
    if (!drawer || !overlay) return;
    drawer.classList.add('drawer--open');
    drawer.removeAttribute('aria-hidden');
    overlay.classList.add('drawer-overlay--visible');
    overlay.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
  }

  function cerrarDrawer() {
    const drawer = document.getElementById('drawer-pedido');
    const overlay = document.getElementById('drawer-overlay');
    if (!drawer || !overlay) return;
    drawer.classList.remove('drawer--open');
    drawer.setAttribute('aria-hidden', 'true');
    overlay.classList.remove('drawer-overlay--visible');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // ── Render ──

  function renderizarCarrito() {
    const total = calcularTotal();
    const unidades = calcularUnidades();
    const vacio = carrito.length === 0;
    const totalStr = formatEur(total);
    const filas = vacio ? '' : carrito.map((l, i) => filaHTML(l, i)).join('');

    // ── Panel desktop ──
    const tablaW = document.getElementById('pedido-tabla-wrapper');
    const tbody = document.getElementById('pedido-lineas');
    const totalEl = document.getElementById('pedido-total');
    const vacioEl = document.getElementById('carrito-vacio');
    const accionesEl = document.getElementById('pedido-acciones');
    const finalizarBtn = document.getElementById('pedido-finalizar') as HTMLButtonElement | null;

    if (totalEl) totalEl.textContent = totalStr;
    if (finalizarBtn) finalizarBtn.disabled = vacio;

    if (vacio) {
      tablaW?.setAttribute('hidden', '');
      accionesEl?.setAttribute('hidden', '');
      vacioEl?.removeAttribute('hidden');
      cerrarFormulario();
    } else {
      vacioEl?.setAttribute('hidden', '');
      tablaW?.removeAttribute('hidden');
      accionesEl?.removeAttribute('hidden');
      if (tbody) tbody.innerHTML = filas;
    }

    // ── Drawer móvil ──
    const tablaWM = document.getElementById('pedido-tabla-wrapper-movil');
    const tbodyM = document.getElementById('pedido-lineas-movil');
    const totalElM = document.getElementById('pedido-total-movil');
    const vacioElM = document.getElementById('carrito-vacio-movil');
    const accionesElM = document.getElementById('pedido-acciones-movil');
    const finalizarBtnM = document.getElementById('pedido-finalizar-movil') as HTMLButtonElement | null;

    if (totalElM) totalElM.textContent = totalStr;
    if (finalizarBtnM) finalizarBtnM.disabled = vacio;

    if (vacio) {
      tablaWM?.setAttribute('hidden', '');
      accionesElM?.setAttribute('hidden', '');
      vacioElM?.removeAttribute('hidden');
      cerrarFormulario();
      cerrarDrawer();
    } else {
      vacioElM?.setAttribute('hidden', '');
      tablaWM?.removeAttribute('hidden');
      accionesElM?.removeAttribute('hidden');
      if (tbodyM) tbodyM.innerHTML = filas;
    }

    // ── Barra flotante ──
    const barra = document.getElementById('barra-pedido-movil');
    const badge = document.getElementById('barra-badge');
    const barraTotal = document.getElementById('barra-total');

    if (badge) badge.textContent = String(unidades);
    if (barraTotal) barraTotal.textContent = totalStr;

    if (barra) {
      if (vacio) {
        barra.classList.remove('barra-movil--visible');
        barra.setAttribute('aria-hidden', 'true');
      } else {
        barra.classList.add('barra-movil--visible');
        barra.removeAttribute('aria-hidden');
      }
    }
  }

  function cerrarFormulario() {
    formularioVisible = false;
    const c1 = document.getElementById('formulario-container');
    if (c1) c1.innerHTML = '';
    const c2 = document.getElementById('formulario-container-movil');
    if (c2) c2.innerHTML = '';
  }

  // ── Formulario ──

  function mostrarFormulario(containerId: string) {
    if (carrito.length === 0) return;
    formularioVisible = true;
    const container = document.getElementById(containerId);
    if (!container) return;

    const resumen = generarResumenTexto();
    const total = formatEur(calcularTotal());

    container.innerHTML = `
      <div class="formulario-pedido" style="margin-top:var(--space-lg);">
        <div class="formulario-pedido__resumen" style="margin-bottom:var(--space-md);padding:var(--space-sm) var(--space-md);background:var(--color-surface-2);border:1px solid var(--color-border);border-radius:var(--radius-sm);font-size:var(--text-sm);">
          <h4 style="font-family:var(--font-display);font-size:var(--text-xs);color:var(--color-text-2);margin-bottom:var(--space-xs);text-transform:uppercase;letter-spacing:0.05em;">Resumen del pedido</h4>
          <pre style="font-family:var(--font-body);font-size:var(--text-sm);color:var(--color-text-1);white-space:pre-wrap;margin:0;">${resumen}</pre>
        </div>
        <form id="pedido-form-${containerId}" style="display:flex;flex-direction:column;">
          <input type="hidden" name="resumen_pedido" value="${resumen.replace(/"/g,'&quot;')}" />
          <input type="hidden" name="total_pedido" value="${total}" />
          <input type="hidden" name="_subject" value="Nuevo pedido — Tienda Moros Viejos" />
          <div style="margin-bottom:var(--space-md);">
            <label style="display:block;font-size:var(--text-sm);font-weight:600;color:var(--color-text-2);margin-bottom:var(--space-xs);">Nombre completo *</label>
            <input type="text" name="nombre" required style="width:100%;padding:var(--space-sm) var(--space-md);border:1px solid var(--color-border);border-radius:var(--radius-sm);font-size:var(--text-base);background:var(--color-surface-1);color:var(--color-text-1);box-sizing:border-box;" />
          </div>
          <div style="margin-bottom:var(--space-md);">
            <label style="display:block;font-size:var(--text-sm);font-weight:600;color:var(--color-text-2);margin-bottom:var(--space-xs);">Correo electrónico *</label>
            <input type="email" name="email" required style="width:100%;padding:var(--space-sm) var(--space-md);border:1px solid var(--color-border);border-radius:var(--radius-sm);font-size:var(--text-base);background:var(--color-surface-1);color:var(--color-text-1);box-sizing:border-box;" />
          </div>
          <div style="margin-bottom:var(--space-md);">
            <label style="display:block;font-size:var(--text-sm);font-weight:600;color:var(--color-text-2);margin-bottom:var(--space-xs);">Teléfono *</label>
            <input type="tel" name="telefono" required style="width:100%;padding:var(--space-sm) var(--space-md);border:1px solid var(--color-border);border-radius:var(--radius-sm);font-size:var(--text-base);background:var(--color-surface-1);color:var(--color-text-1);box-sizing:border-box;" />
          </div>
          <div style="margin-bottom:var(--space-md);">
            <label style="display:block;font-size:var(--text-sm);font-weight:600;color:var(--color-text-2);margin-bottom:var(--space-xs);">Notas adicionales</label>
            <textarea name="notas" rows="3" placeholder="Tallas, colores…" style="width:100%;padding:var(--space-sm) var(--space-md);border:1px solid var(--color-border);border-radius:var(--radius-sm);font-size:var(--text-base);background:var(--color-surface-1);color:var(--color-text-1);resize:vertical;box-sizing:border-box;"></textarea>
          </div>
          <button type="submit" class="btn btn--primary btn--full" id="pedido-submit-${containerId}">Enviar pedido</button>
        </form>
        <p style="font-size:var(--text-xs);color:var(--color-text-3);text-align:center;margin-top:var(--space-md);">Al enviar recibirás una copia. El responsable se pondrá en contacto para confirmar el pago y la entrega.</p>
      </div>
    `;

    const form = document.getElementById(`pedido-form-${containerId}`) as HTMLFormElement;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const resumenInput = form.querySelector<HTMLInputElement>('[name="resumen_pedido"]');
      const totalInput = form.querySelector<HTMLInputElement>('[name="total_pedido"]');
      if (resumenInput) resumenInput.value = generarResumenTexto();
      if (totalInput) totalInput.value = formatEur(calcularTotal());

      const emailInput = form.querySelector<HTMLInputElement>('[name="email"]');
      const existingReply = form.querySelector<HTMLInputElement>('[name="_replyto"]');
      if (emailInput && !existingReply) {
        const h = document.createElement('input');
        h.type = 'hidden'; h.name = '_replyto'; h.value = emailInput.value;
        form.appendChild(h);
      }

      const submitBtn = document.getElementById(`pedido-submit-${containerId}`) as HTMLButtonElement;
      const fields = form.querySelectorAll<HTMLInputElement|HTMLTextAreaElement>('input,textarea');
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Enviando…'; }
      fields.forEach(f => (f.disabled = true));

      try {
        const data = new FormData(form);
        const res = await fetch('https://formspree.io/f/FORMSPREE_ID', {
          method: 'POST', body: data, headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.setAttribute('hidden', '');
          container.querySelector('p:last-child')?.setAttribute('hidden', '');
          const exito = document.createElement('div');
          exito.style.cssText = 'text-align:center;padding:var(--space-lg) 0;display:flex;flex-direction:column;align-items:center;gap:var(--space-md);';
          exito.innerHTML = `<svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="var(--color-accent)" stroke-width="2"/><path d="M14 24l7 7 13-13" stroke="var(--color-accent)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg><p style="font-size:var(--text-sm);color:var(--color-text-2);">¡Pedido recibido! Nos pondremos en contacto contigo en breve.</p><button type="button" class="btn btn--outline" id="pedido-otro-${containerId}">Hacer otro pedido</button>`;
          container.appendChild(exito);
          document.getElementById(`pedido-otro-${containerId}`)?.addEventListener('click', () => {
            carrito = []; renderizarCarrito(); cerrarFormulario();
          });
        } else {
          mostrarError(container, form);
        }
      } catch {
        mostrarError(container, form);
      }
    });
  }

  function mostrarError(container: HTMLElement, form: HTMLFormElement) {
    form.setAttribute('hidden', '');
    container.querySelector('p:last-child')?.setAttribute('hidden', '');
    const err = document.createElement('div');
    err.style.cssText = 'text-align:center;padding:var(--space-lg) 0;display:flex;flex-direction:column;align-items:center;gap:var(--space-md);';
    err.innerHTML = `<svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="var(--color-accent)" stroke-width="2"/><path d="M16 16l16 16M32 16L16 32" stroke="var(--color-accent)" stroke-width="3" stroke-linecap="round"/></svg><p style="font-size:var(--text-sm);color:var(--color-text-2);">Hubo un problema. Contacta en <strong>morosviejos@mojacar.es</strong></p><button type="button" class="btn btn--outline retry-btn">Reintentar</button>`;
    container.appendChild(err);
    (err.querySelector('.retry-btn') as HTMLButtonElement)?.addEventListener('click', () => {
      err.remove();
      form.removeAttribute('hidden');
      container.querySelector('p:last-child')?.removeAttribute('hidden');
      const sb = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (sb) { sb.disabled = false; sb.textContent = 'Enviar pedido'; }
      form.querySelectorAll('input,textarea').forEach(f => (f as HTMLInputElement|HTMLTextAreaElement).disabled = false);
    });
  }

  // ── Event Listeners ──

  // Añadir desde catálogo
  document.getElementById('tienda-catalogo')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.producto-card__add');
    if (!btn) return;
    const card = btn.closest<HTMLElement>('.producto-card');
    if (!card) return;
    const productoId = card.dataset.productoId || '';
    const nombre = card.querySelector('.producto-card__name')?.textContent?.trim() || '';
    const tallaSelect = card.querySelector<HTMLSelectElement>('.producto-card__talla');
    const talla = tallaSelect?.value || '';
    if (tallaSelect && !talla) {
      tallaSelect.style.borderColor = 'var(--color-accent)';
      setTimeout(() => tallaSelect.style.borderColor = '', 1500);
      return;
    }
    const qtyInput = card.querySelector<HTMLInputElement>('.producto-card__qty');
    const cantidad = qtyInput ? Math.max(1, Math.min(20, parseInt(qtyInput.value) || 1)) : 1;
    if (qtyInput) qtyInput.value = '1';
    if (tallaSelect) tallaSelect.value = '';
    const precioEl = card.querySelector('.producto-card__price');
    const precio = precioEl ? parseFloat((precioEl.textContent || '0').replace(/[^0-9,.]/g, '').replace(',', '.')) : 0;

    const existente = carrito.find(l => l.id === productoId && l.talla === talla);
    if (existente) {
      existente.cantidad = Math.min(20, existente.cantidad + cantidad);
    } else {
      carrito.push({ id: productoId, nombre, talla, cantidad, precioUnit: precio });
    }
    renderizarCarrito();
  });

  // Controles de cantidad y eliminar en tabla (delegación)
  function attachTablaListeners(tbodyId: string) {
    const tbody = document.getElementById(tbodyId);
    tbody?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      // +/−
      const ctlBtn = target.closest<HTMLButtonElement>('.icon-btn--cantidad');
      if (ctlBtn) {
        const accion = ctlBtn.dataset.accion;
        const idx = parseInt(ctlBtn.dataset.idx || '');
        if (idx >= 0 && idx < carrito.length) {
          if (accion === 'restar') {
            if (carrito[idx].cantidad > 1) { carrito[idx].cantidad--; }
            else { carrito.splice(idx, 1); }
          } else if (accion === 'sumar') {
            carrito[idx].cantidad = Math.min(20, carrito[idx].cantidad + 1);
          }
          renderizarCarrito();
        }
        return;
      }
      // Eliminar
      const delBtn = target.closest<HTMLButtonElement>('.icon-btn--eliminar');
      if (delBtn) {
        const idx = parseInt(delBtn.dataset.eliminar || '');
        if (idx >= 0 && idx < carrito.length) {
          carrito.splice(idx, 1);
          renderizarCarrito();
        }
      }
    });
  }

  attachTablaListeners('pedido-lineas');
  attachTablaListeners('pedido-lineas-movil');

  // Vaciar (panel desktop)
  document.getElementById('pedido-vaciar')?.addEventListener('click', () => { carrito = []; renderizarCarrito(); });

  // Vaciar (drawer móvil)
  document.getElementById('pedido-vaciar-movil')?.addEventListener('click', () => { carrito = []; renderizarCarrito(); });

  // Finalizar (panel desktop)
  document.getElementById('pedido-finalizar')?.addEventListener('click', () => mostrarFormulario('formulario-container'));

  // Finalizar (drawer móvil)
  document.getElementById('pedido-finalizar-movil')?.addEventListener('click', () => mostrarFormulario('formulario-container-movil'));

  // Abrir drawer
  document.getElementById('barra-abrir-drawer')?.addEventListener('click', abrirDrawer);

  // Cerrar drawer (botón X)
  document.getElementById('drawer-cerrar')?.addEventListener('click', cerrarDrawer);

  // Cerrar drawer (overlay)
  document.getElementById('drawer-overlay')?.addEventListener('click', cerrarDrawer);

  // Cerrar drawer con Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') cerrarDrawer();
  });
</script>
